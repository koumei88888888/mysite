---
import { MOVIE_TYPES, BASE } from '../config';
import { starsHTML } from '../utils';

interface Props {
  title: string;
  director: string;
  year: number;
  country: string;
  type: string;
  score: number;
  tags: string[];
  thumbnail: string;
  summary: string;
  slug: string;
}

const { title, director, year, country, type, score, tags, thumbnail, summary, slug } = Astro.props;
const typeConfig = MOVIE_TYPES.find(t => t.id === type) ?? { label: type, emoji: '🎬', color: '#ef4444' };
const base = BASE;
---

<a class="review-card" href={`${base}movie/${slug}/`}>
  <img class="card-thumb" src={thumbnail} alt={title} loading="lazy">
  <div class="card-body">
    <div class="card-meta">
      <span class="card-category" style={`background:${typeConfig.color}22;color:${typeConfig.color}`}>
        {typeConfig.emoji} {typeConfig.label}
      </span>
      <span class="card-date">{year}</span>
    </div>
    <div class="card-title">{title}</div>
    <div class="card-subtitle">
      {director}
      <span class="platform-badge">🌍 {country}</span>
    </div>
    <p class="card-summary">{summary}</p>
    <div class="card-tags">
      {tags.map(t => <span class="card-tag">{t}</span>)}
    </div>
    <div class="card-footer">
      <div class="card-score">
        <span class="score-num">{score.toFixed(1)}</span>
        <span class="score-denom">/ 5.0</span>
      </div>
      <div class="card-stars" set:html={starsHTML(score)} />
    </div>
  </div>
</a>

---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import MovieCard from '../../components/MovieCard.astro';
import { MOVIE_TYPES } from '../../config';

const entries = (await getCollection('movie'))
  .sort((a, b) => b.data.date.localeCompare(a.data.date));
---

<BaseLayout title="映画" activeNav="movie">
  <div class="page-header">
    <p class="eyebrow">MOVIE</p>
    <h1>映<span>画</span></h1>
    <p class="desc">観た映画の個人レビュー。</p>
  </div>

  <div class="controls">
    <div class="filter-group">
      <label for="f-type">タグ</label>
      <select id="f-type">
        <option value="">すべて</option>
        {MOVIE_TYPES.map(t => <option value={t.id}>{t.emoji} {t.label}</option>)}
      </select>
    </div>
    <div class="filter-group">
      <label for="f-score">最低スコア</label>
      <input type="range" id="f-score" min="1" max="5" step="0.5" value="1">
      <span class="score-display" id="score-val">1.0</span>
    </div>
    <div class="spacer"></div>
    <span class="count-badge"><strong id="count">{entries.length}</strong> 件</span>
  </div>

  <div class="card-grid">
    {entries.map(e => (
      <div class="filter-item"
           data-type={e.data.type}
           data-score={e.data.score}>
        <MovieCard slug={e.slug} {...e.data} />
      </div>
    ))}
    <div class="empty-state" id="empty-state" style="display:none">
      <div class="icon">🔍</div>
      <p>条件に合う映画が見つかりませんでした。</p>
    </div>
  </div>
</BaseLayout>

<style>
  .filter-item { display: contents; }
  .filter-item.hidden { display: none; }
</style>

<script>
  const scoreInput = document.getElementById('f-score') as HTMLInputElement;
  const scoreVal   = document.getElementById('score-val')!;
  const countEl    = document.getElementById('count')!;
  const emptyEl    = document.getElementById('empty-state')!;
  const items      = [...document.querySelectorAll<HTMLElement>('.filter-item')];

  scoreInput.addEventListener('input', () => {
    scoreVal.textContent = parseFloat(scoreInput.value).toFixed(1);
    applyFilters();
  });
  document.getElementById('f-type')!.addEventListener('change', applyFilters);

  function applyFilters() {
    const type     = (document.getElementById('f-type') as HTMLSelectElement).value;
    const minScore = parseFloat(scoreInput.value);
    let visible = 0;
    items.forEach(item => {
      const show = (!type || item.dataset.type === type)
                && parseFloat(item.dataset.score!) >= minScore;
      item.classList.toggle('hidden', !show);
      if (show) visible++;
    });
    countEl.textContent   = String(visible);
    emptyEl.style.display = visible === 0 ? 'block' : 'none';
  }
</script>
